# ==============================================
# liangqy-dev .gitignore
# ==============================================

# ---- 环境变量（含敏感信息，不提交）----
.env

# ---- 数据目录（体积大，不提交）----
mysql/data/
redis/data/
elasticsearch/data/
clickhouse/data/

# ---- 日志文件 ----
nginx/logs/*
mysql/logs/*
php/logs/**/*
elasticsearch/logs/*
clickhouse/logs/
kafka/logs/*

# 保留日志目录本身
!nginx/logs/.gitkeep
!mysql/logs/.gitkeep
!php/logs/php74/.gitkeep
!php/logs/php83/.gitkeep
!php/logs/php84/.gitkeep
!elasticsearch/logs/.gitkeep

# ---- Nginx 站点配置（只保留 default.conf）----
nginx/conf.d/*
!nginx/conf.d/default.conf

# ---- SSL 证书及配置（不提交）----
nginx/ssl/*
!nginx/ssl/.gitkeep

# ---- 代码目录（各项目有自己的仓库）----
www/*
!www/.gitkeep

# ---- 系统文件 ----
.DS_Store
Thumbs.db
desktop.ini

# ---- 编辑器 ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Docker 构建缓存 ----
**/.docker-build-cache/
