# ==============================================
# liangqy-dev 开发环境配置示例
# 使用方法：cp .env.example .env，然后修改 .env 中的值
# 注意：.env 已加入 .gitignore，请勿将真实密码提交到版本库
# ==============================================

# 项目名称
COMPOSE_PROJECT_NAME=liangqy-dev

# 代码目录（相对于 docker-compose.yml 所在目录）
CODE_DIR=./www

# ---- MySQL ----
MYSQL_VERSION=9.0.0
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=default_db
MYSQL_USER=developer
MYSQL_PASSWORD=your_dev_password
MYSQL_PORT=3306

# ---- Redis ----
REDIS_VERSION=7.2
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ---- Nginx ----
NGINX_VERSION=1.27.4
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---- PHP ----
PHP74_PORT=9074
PHP83_PORT=9083
PHP84_PORT=9084

# ---- Elasticsearch ----
ES_VERSION=8.13.0
ES_PORT=9200
ES_TCP_PORT=9300
ES_PASSWORD=your_es_password

# ---- ClickHouse ----
CLICKHOUSE_VERSION=24.3
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password

# ---- Kafka ----
# 宿主机访问端口（容器内部固定使用 9092）
KAFKA_EXTERNAL_PORT=19092
# Kafka UI 管理界面端口
KAFKA_UI_PORT=8080
