# ============================================================
# Kafka KRaft 模式配置（不依赖 Zookeeper）
# bitnami/kafka 镜像文档:
# https://github.com/bitnami/containers/tree/main/bitnami/kafka
# ============================================================

# ---- 节点角色（KRaft 模式：controller + broker 合一）----
KAFKA_CFG_PROCESS_ROLES=controller,broker
KAFKA_CFG_NODE_ID=1
KAFKA_CFG_CONTROLLER_QUORUM_VOTERS=1@kafka:9093

# ---- 监听器配置 ----
# PLAINTEXT: 供内部容器访问（容器名 kafka:9092）
# EXTERNAL: 供宿主机/外部访问（localhost:19092）
# CONTROLLER: KRaft 内部选举
KAFKA_CFG_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093,EXTERNAL://:19092
KAFKA_CFG_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092,EXTERNAL://localhost:19092
KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT,EXTERNAL:PLAINTEXT
KAFKA_CFG_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_CFG_INTER_BROKER_LISTENER_NAME=PLAINTEXT

# ---- 日志/数据目录 ----
KAFKA_CFG_LOG_DIRS=/bitnami/kafka/data

# ---- Topic 默认配置 ----
KAFKA_CFG_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_CFG_NUM_PARTITIONS=3
KAFKA_CFG_DEFAULT_REPLICATION_FACTOR=1
KAFKA_CFG_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_CFG_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_CFG_TRANSACTION_STATE_LOG_MIN_ISR=1

# ---- 消息保留策略 ----
# 保留时间（小时），-1 表示不限
KAFKA_CFG_LOG_RETENTION_HOURS=168
# 单个 Topic 最大 bytes（-1 不限）
KAFKA_CFG_LOG_RETENTION_BYTES=-1
# 单个 Segment 最大大小
KAFKA_CFG_LOG_SEGMENT_BYTES=1073741824
# 清理检查间隔（ms）
KAFKA_CFG_LOG_RETENTION_CHECK_INTERVAL_MS=300000

# ---- 性能 ----
KAFKA_CFG_NUM_NETWORK_THREADS=3
KAFKA_CFG_NUM_IO_THREADS=8
KAFKA_CFG_SOCKET_SEND_BUFFER_BYTES=102400
KAFKA_CFG_SOCKET_RECEIVE_BUFFER_BYTES=102400
KAFKA_CFG_SOCKET_REQUEST_MAX_BYTES=104857600

# ---- 时区 ----
TZ=Asia/Shanghai
